<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:text="쿠폰관리"
        android:textColor="#1f2937"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnCouponManagementIssue"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/button_style"
        android:text="신규쿠폰 생성"
        android:textColor="@android:color/white"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnCouponManagementRecharge"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/button_server"
        android:text="기존쿠폰 충전"
        android:textColor="@android:color/white"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnCouponManagementList"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/button_style"
        android:text="쿠폰 조회"
        android:textColor="@android:color/white"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnCouponManagementQr"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/button_server"
        android:text="QR 스캔"
        android:textColor="@android:color/white"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnCouponManagementBack"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/button_secondary"
        android:text="뒤로가기"
        android:textColor="#333"
        android:textSize="16sp" />
</LinearLayout>
